{
  "name": "proxy-control-center",
  "version": "0.1.0",
  "private": true,
  "description": "Proxy Control Center monorepo",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @proxy-control-center/backend dev\" \"pnpm --filter @proxy-control-center/frontend dev\"",
    "build": "pnpm --filter @proxy-control-center/backend build && pnpm --filter @proxy-control-center/frontend build",
    "start": "pnpm --filter @proxy-control-center/backend start",
    "smoke": "node scripts/smoke.mjs",
    "smoke:all": "node scripts/smoke-all.mjs",
    "smoke:api-gap": "node scripts/api-gap-smoke.mjs",
    "smoke:auth": "node scripts/auth-smoke.mjs",
    "smoke:backup-error": "node scripts/backup-error-smoke.mjs",
    "smoke:backup-cleanup": "node scripts/backup-cleanup-warning-smoke.mjs",
    "smoke:cli": "node scripts/cli-smoke.mjs",
    "smoke:compose": "node scripts/compose-smoke.mjs",
    "smoke:compose-required": "node scripts/compose-required-smoke.mjs",
    "smoke:engine": "node scripts/engine-smoke.mjs",
    "smoke:engine-log-error": "node scripts/engine-log-error-smoke.mjs",
    "smoke:engine-log": "node scripts/engine-log-smoke.mjs",
    "smoke:engine-rollback": "node scripts/engine-rollback-smoke.mjs",
    "smoke:frontend-contract": "node scripts/frontend-contract-smoke.mjs",
    "smoke:install": "node scripts/install-smoke.mjs",
    "smoke:locks": "node scripts/locks-smoke.mjs",
    "smoke:postgres": "node scripts/postgres-smoke.mjs",
    "smoke:production-config": "node scripts/production-config-smoke.mjs",
    "smoke:redis-required": "node scripts/redis-required-smoke.mjs",
    "smoke:runtime-config": "node scripts/runtime-config-smoke.mjs",
    "smoke:secrets": "node scripts/secrets-smoke.mjs",
    "smoke:share-rate": "node scripts/share-rate-smoke.mjs",
    "smoke:subscription-security": "node scripts/subscription-security-smoke.mjs",
    "smoke:subscription-scheduler": "node scripts/subscription-scheduler-smoke.mjs",
    "smoke:traffic-aggregate": "node scripts/traffic-aggregate-smoke.mjs",
    "check:deploy": "node scripts/deploy-check.mjs",
    "test:adapters": "node scripts/adapter-golden.mjs",
    "lint": "pnpm --filter @proxy-control-center/frontend lint",
    "typecheck": "pnpm --filter @proxy-control-center/backend typecheck && pnpm --filter @proxy-control-center/frontend typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  }
}
