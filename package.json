{
  "name": "proxy-control-center",
  "version": "0.1.0",
  "private": true,
  "description": "Proxy Control Center monorepo",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @proxy-control-center/backend dev\" \"pnpm --filter @proxy-control-center/frontend dev\"",
    "build": "pnpm --filter @proxy-control-center/backend build && pnpm --filter @proxy-control-center/frontend build",
    "start": "pnpm --filter @proxy-control-center/backend start",
    "lint": "pnpm --filter @proxy-control-center/frontend lint",
    "typecheck": "pnpm --filter @proxy-control-center/backend typecheck && pnpm --filter @proxy-control-center/frontend typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  }
}
